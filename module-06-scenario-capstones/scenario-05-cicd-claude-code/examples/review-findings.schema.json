{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "severity": { "enum": ["low", "med", "high"] },
          "category": { "enum": ["correctness", "security", "tests", "style", "other"] },
          "category_detail": { "type": ["string", "null"] },
          "detected_pattern": {
            "type": "string",
            "description": "Short tag for the issue pattern — used for dismissal analytics."
          },
          "issue": { "type": "string" },
          "suggested_fix": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["file", "line", "severity", "category", "issue"]
      }
    },
    "new_vs_prior": {
      "type": "object",
      "properties": {
        "new": { "type": "integer" },
        "still_unaddressed": { "type": "integer" },
        "resolved_since_last_run": { "type": "integer" }
      }
    }
  },
  "required": ["findings"]
}
